@page "/"

<PageTitle>SouthHome</PageTitle>

<div class="home-container">
    <!-- 主内容区 -->
    <div class="home-content">
        <!-- 圆形头像 -->
        <div class="avatar-container">
            <img src="/images/avatar.png"
                 alt="Avatar"
                 class="avatar" />
        </div>

        <!-- 卡片区域 -->
        <div class="cards-container">

            <!-- 项目卡片 -->
            <FluentCard Class="home-card" Elevation="8">
                <FluentStack Orientation="Orientation.Vertical" Gap="12">
                    <FluentStack Orientation="Orientation.Horizontal" Gap="8" VerticalAlignment="VerticalAlignment.Center">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Folder())" />
                        <span class="card-title">
                            项目
                        </span>
                    </FluentStack>
                    <span class="card-desc">
                        展示个人作品和开源项目
                    </span>
                    <div class="developing">
                        <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span> 开发中
                    </div>
                </FluentStack>
            </FluentCard>

            <!-- 博客卡片 -->
            <a href="/blog" target="_blank" style="text-decoration:none;">
                <FluentCard Class="home-card" Elevation="8">
                    <FluentStack Orientation="Orientation.Vertical" Gap="12">
                        <FluentStack Orientation="Orientation.Horizontal" Gap="8" VerticalAlignment="VerticalAlignment.Center">
                            <FluentIcon Value="@(new Icons.Regular.Size24.BookOpen())" />
                            <span class="card-title">
                                博客
                            </span>
                        </FluentStack>
                        <span class="card-desc">
                            技术文章和学习笔记
                        </span>
                    </FluentStack>
                </FluentCard>
            </a>

            <!-- 游戏卡片 -->
            <FluentCard Class="home-card" Elevation="8">
                <FluentStack Orientation="Orientation.Vertical" Gap="12">
                    <FluentStack Orientation="Orientation.Horizontal" Gap="8" VerticalAlignment="VerticalAlignment.Center">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Games())" />
                        <span class="card-title">
                            游戏
                        </span>
                    </FluentStack>
                    <span class="card-desc">
                        游戏开发与分享
                    </span>
                    <div class="developing">
                        <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span> 开发中
                    </div>
                </FluentStack>
            </FluentCard>

            <!-- 联系方式卡片 -->
            <FluentCard Class="home-card" Elevation="8">
                <FluentStack Orientation="Orientation.Vertical" Gap="12">
                    <FluentStack Orientation="Orientation.Horizontal" Gap="8" VerticalAlignment="VerticalAlignment.Center">
                        <FluentIcon Value="@(new Icons.Regular.Size24.PersonInfo())" />
                        <span class="card-title">
                            联系方式
                        </span>
                    </FluentStack>
                    <FluentStack Orientation="Orientation.Horizontal" Gap="8">
                        <FluentButton Appearance="Appearance.Outline" Style="font-size:0.85rem;padding:4px 12px;">
                            GitHub
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" Style="font-size:0.85rem;padding:4px 12px;">
                            Email
                        </FluentButton>
                    </FluentStack>
                    <div class="developing">
                        <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span> 开发中
                    </div>
                </FluentStack>
            </FluentCard>

        </div>
    </div>
</div>

<style>
    .home-container {
        position: relative;
        min-height: calc(100vh - 86px);
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url('/images/home-bg.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .home-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 60px;
        padding: 60px 40px;
        min-height: calc(100vh - 86px);
        width: 60%;
        max-width: 1000px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
    }

    .avatar-container {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-top: 40px;
    }

    .avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 4px solid #dc2626;
        box-shadow: 0 8px 32px rgba(220, 38, 38, 0.3);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .avatar:hover {
        transform: scale(1.05);
        box-shadow: 0 12px 40px rgba(220, 38, 38, 0.4);
    }

    .card-icon {
        font-size: 1.5rem;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .card-desc {
        color: #666;
        font-size: 0.9rem;
    }

    .developing {
        color: #dc2626;
        font-size: 0.8rem;
        margin-top: 8px;
        animation: bounce 1.4s infinite ease-in-out both;
    }

    .developing .dot {
        display: inline-block;
    }

    @@keyframes bounce {
        0%, 80%, 100% {
            transform: translateY(0);
        }
        40% {
            transform: translateY(-4px);
        }
    }

    .cards-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 20px;
        width: 100%;
        margin-top: auto;
        margin-bottom: auto;
        margin-top: 15%;
    }

    .home-card {
        width: 280px;
        padding: 24px;
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        margin-left: 0;
        margin-right: 0;
    }

    .home-card:hover {
        transform: translateY(-4px);
    }

    @@media (max-width: 768px) {
        .home-content {
            padding: 20px;
            gap: 24px;
        }

        .avatar {
            width: 100px;
            height: 100px;
        }

        .home-card {
            width: 100%;
            max-width: 300px;
        }
    }
</style>