@page "/"

<PageTitle>SouthHome</PageTitle>

<FluentStack Orientation="Orientation.Vertical"
             Gap="30"
             Style="padding:40px;max-width:1200px;margin:auto;">

    <!-- 圆形头像 -->
    <FluentStack Style="display:flex;justify-content:center;align-items:center;">
        <img src="/images/avatar.png"
             style="width:120px;height:120px;border-radius:50%;border:4px solid #dc2626;" />
    </FluentStack>

    <!-- 卡片区域 -->
    <FluentStack Orientation="Orientation.Horizontal"
                 Wrap="true"
                 Gap="24">

        <!-- 个人信息 -->
        <FluentCard Style="width:300px;padding:24px;border-radius:16px;" Elevation="8">

            <FluentStack Gap="12">
                <FluentButton Appearance="Appearance.Stealth">
                    项目
                </FluentButton>

            </FluentStack>

        </FluentCard>

        <a href="/blog" target="_blank" style="text-decoration:none;">
            <FluentCard Style="width:300px;padding:24px;border-radius:16px;cursor:pointer;" Elevation="8">

                <FluentStack Gap="12">

                    <FluentTypography Style="font-size:1.2rem;font-weight:500;">
                        博客
                    </FluentTypography>

                </FluentStack>

            </FluentCard>
        </a>

        <FluentCard Style="width:300px;padding:24px;border-radius:16px;" Elevation="8">

            <FluentStack Gap="12">

                <FluentBadge Appearance="Appearance.Accent">
                    游戏
                </FluentBadge>

            </FluentStack>

        </FluentCard>

        <FluentCard Style="width:300px;padding:24px;border-radius:16px;" Elevation="8">

            <FluentStack Gap="12">

                <FluentButton Appearance="Appearance.Outline">
                    GitHub
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline">
                    Email
                </FluentButton>

            </FluentStack>

        </FluentCard>

    </FluentStack>

</FluentStack>