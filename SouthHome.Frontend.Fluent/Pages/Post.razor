@page "/post/{id}"

@using System.Text
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>@(pageTitle) - SouthHome</PageTitle>

<FluentStack Orientation="Orientation.Vertical"
             Gap="24"
             Style="padding:40px;max-width:900px;margin:auto;">

    <!-- 顶部导航 -->
    <FluentStack Orientation="Orientation.Horizontal">
        <FluentButton Appearance="Appearance.Outline" OnClick="GoBack">
            ← 返回列表
        </FluentButton>
    </FluentStack>

    @if (isLoading)
    {
        <FluentStack Style="padding:60px;text-align:center;">
            <FluentTypography Style="color:#999;">加载中...</FluentTypography>
        </FluentStack>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <FluentStack Style="padding:60px;text-align:center;">
            <FluentTypography Style="color:#dc2626;">@errorMessage</FluentTypography>
        </FluentStack>
    }
    else
    {
        <!-- 文章头部 -->
        <FluentCard Style="padding:40px;border-radius:16px;" Elevation="0">

            <FluentStack Orientation="Orientation.Vertical" Gap="20">

                <!-- 标题 -->
                <FluentTypography Style="font-size:2.2rem;font-weight:700;">
                    @postTitle
                </FluentTypography>

                <!-- 元信息 -->
                <FluentStack Orientation="Orientation.Horizontal" Gap="24" Style="color:#999;">
                    <FluentTypography>
                        @postAuthor
                    </FluentTypography>
                    <FluentTypography>
                        @postDate
                    </FluentTypography>
                </FluentStack>

            </FluentStack>

        </FluentCard>

        <!-- 分隔线 -->
        <div style="height:2px;background:linear-gradient(to right, transparent, #e5e5e5, transparent);" />

        <!-- 内容容器（包含文章内容和目录） -->
        <div style="position:relative;">

            <!-- Markdown 内容 -->
            <FluentCard Style="padding:40px;border-radius:16px;" Elevation="0">

                <div class="markdown-content" id="article-content">
                    @((MarkupString)markdownContent)
                </div>

            </FluentCard>

            <!-- 目录栏 -->
            @if (tableOfContents.Count > 0)
            {
                <div class="toc-container">
                    <div class="toc-header">
                        <FluentTypography Style="font-weight:600;font-size:0.95rem;">
                            目录
                        </FluentTypography>
                    </div>
                    <FluentStack Orientation="Orientation.Vertical" Gap="4">

                        @foreach (var item in tableOfContents)
                        {
                            <div class="toc-item @GetTocActiveClass(item.Index)"
                                 style="padding-left:@(item.Level * 16)px;"
                                 @onclick="@(() => ScrollToSection(item.Anchor.Substring(1)))">
                                @item.Text
                            </div>
                        }

                    </FluentStack>
                </div>
            }

        </div>

        <!-- 回到顶部按钮 -->
        <button id="back-to-top" class="back-to-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
            ↑
        </button>

    }

</FluentStack>

<style>
    .markdown-content {
        font-size: 1.1rem;
        line-height: 1.8;
        color: #333;
        scroll-margin-top: 20px;
    }

    .markdown-content h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 2em 0 1em;
        border-bottom: 2px solid #dc2626;
        scroll-margin-top: 80px;
    }

    .markdown-content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 1.5em 0 1em;
        border-bottom: 1px solid #e5e5e5;
        scroll-margin-top: 80px;
    }

    .markdown-content h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin: 1.2em 0 0.6em;
        scroll-margin-top: 80px;
    }

    .markdown-content h4 {
        font-size: 1rem;
        font-weight: 600;
        margin: 1em 0 0.5em;
        scroll-margin-top: 80px;
    }

    .markdown-content p {
        margin: 1em 0;
    }

    .markdown-content ul, .markdown-content ol {
        margin: 1em 0;
        padding-left: 2em;
    }

    .markdown-content li {
        margin: 0.5em 0;
    }

    .markdown-content code {
        background: #f5f5f7;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: 'Consolas', monospace;
        color: #e74c3c;
    }

    .markdown-content pre {
        background: #1a1a1a;
        color: #f5f5f5;
        padding: 20px;
        border-radius: 12px;
        overflow-x: auto;
        margin: 1.5em 0;
    }

    .markdown-content pre code {
        background: none;
        color: #f5f5f5;
    }

    .markdown-content blockquote {
        border-left: 4px solid #dc2626;
        padding: 12px 20px;
        margin: 1.5em 0;
        background: #fafafa;
        color: #666;
    }

    .markdown-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
    }

    .markdown-content th, .markdown-content td {
        border: 1px solid #e5e5e5;
        padding: 12px;
        text-align: left;
    }

    .markdown-content th {
        background: #f5f5f7;
    }

    .markdown-content a {
        color: #dc2626;
    }

    /* 目录样式 */
    .toc-container {
        position: fixed;
        right: 20px;
        top: 120px;
        max-width: 250px;
        max-height: 70vh;
        overflow-y: auto;
        background: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        padding: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        backdrop-filter: blur(10px);
        z-index: 1000;
    }

    .toc-header {
        margin-bottom: 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e5e5e5;
    }

    .toc-item {
        display: block;
        padding: 8px 12px;
        color: #666;
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .toc-item:hover {
        background: #f5f5f7;
        color: #dc2626;
    }

    .toc-item.active {
        color: #dc2626;
        font-weight: 500;
        background: rgba(220, 38, 38, 0.1);
        border-left: 3px solid #dc2626;
    }

    /* 回到顶部按钮 */
    .back-to-top {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: none;
        background: #dc2626;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
        transition: all 0.3s;
        opacity: 0;
        visibility: hidden;
        z-index: 999;
    }

    .back-to-top.visible {
        opacity: 1;
        visibility: visible;
    }

    .back-to-top:hover {
        background: #e53935;
        transform: translateY(-3px);
    }

    /* 响应式 */
    @@media (max-width: 1200px) {
        .toc-container {
            display: none;
        }
    }
</style>

<script>
    // 监听滚动，高亮当前目录项
    window.addEventListener('scroll', function() {
        // 高亮目录项
        const tocItems = document.querySelectorAll('.toc-item');
        const sections = document.querySelectorAll('.markdown-content h1, .markdown-content h2, .markdown-content h3');

        let currentSection = '';
        sections.forEach(function(section, index) {
            const sectionTop = section.offsetTop - 120;
            if (window.pageYOffset >= sectionTop) {
                currentSection = section.id;
            }
        });

        tocItems.forEach(function(item) {
            item.classList.remove('active');
            if (item.getAttribute('href') === '#' + currentSection) {
                item.classList.add('active');
            }
        });

        // 显示/隐藏回到顶部按钮
        const backToTopBtn = document.getElementById('back-to-top');
        if (window.pageYOffset > 300) {
            backToTopBtn.classList.add('visible');
        } else {
            backToTopBtn.classList.remove('visible');
        }
    });
</script>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private bool isLoading = true;
    private string? errorMessage;
    private string markdownContent = string.Empty;
    private string pageTitle = "文章";
    private string postTitle = string.Empty;
    private string postAuthor = "Nan Sun";
    private string postDate = string.Empty;

    private List<TocItem> tableOfContents = new();

    public class TocItem
    {
        public int Index { get; set; }
        public string Text { get; set; }
        public string Anchor { get; set; }
        public int Level { get; set; }
    }

    private Dictionary<string, (string Title, string Summary, List<string> Tags)> postMetadata = new()
    {
        {
            "1", (
                "ASP.NET Core 中间件深入解析",
                "深入了解 ASP.NET Core 中间件的工作原理。",
                new List<string> { ".NET", "后端" }
            )
        },
        {
            "2", (
                "Kubernetes 集群部署最佳实践",
                "分享在生产环境中部署 Kubernetes 集群的经验。",
                new List<string> { "Kubernetes", "DevOps" }
            )
        },
        {
            "3", (
                "MongoDB 性能优化指南",
                "从索引设计到查询优化，全面介绍 MongoDB 性能调优的技巧。",
                new List<string> { "MongoDB", "数据库" }
            )
        },
        {
            "4", (
                "Java 并发编程实战",
                "深入理解 Java 并发编程的核心概念，包括线程池、锁机制等。",
                new List<string> { "Java", "后端" }
            )
        },
        {
            "5", (
                "微服务架构设计模式",
                "探讨微服务架构中的常见设计模式，包括服务发现、熔断降级等。",
                new List<string> { "架构", ".NET", "DevOps" }
            )
        },
        {
            "6", (
                "Docker 容器化部署指南",
                "从零开始学习 Docker 容器技术，掌握镜像构建和容器编排。",
                new List<string> { "Docker", "DevOps" }
            )
        }
    };

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Id))
        {
            errorMessage = "缺少文章 ID";
            isLoading = false;
            return;
        }

        await LoadPostData();
        isLoading = false;
    }

    private async Task LoadPostData()
    {
        try
        {
            var filePath = $"/content/post-{Id}.md";
            var content = await Http.GetStringAsync(filePath);
            markdownContent = ParseMarkdownWithAnchors(content);
            ExtractTableOfContents(content);

            if (postMetadata.TryGetValue(Id, out var meta))
            {
                pageTitle = meta.Title;
                postTitle = meta.Title;
                postDate = DateTime.Now.ToString("yyyy-MM-dd");
            }
            else
            {
                var lines = content.Split('\n');
                if (lines.Length > 0)
                {
                    var firstLine = lines[0].Trim();
                    if (firstLine.StartsWith("# "))
                    {
                        postTitle = firstLine.Substring(2);
                    }
                    else
                    {
                        postTitle = $"文章 {Id}";
                    }
                }
                pageTitle = postTitle;
                postDate = DateTime.Now.ToString("yyyy-MM-dd");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"无法加载文章：{ex.Message}";
        }
    }

    private string ParseMarkdownWithAnchors(string markdown)
    {
        if (string.IsNullOrEmpty(markdown))
            return string.Empty;

        var lines = markdown.Split('\n');
        var result = new StringBuilder();
        bool inCodeBlock = false;
        int sectionIndex = 0;

        foreach (var line in lines)
        {
            var trimmedLine = line.Trim();

            // 处理代码块
            if (trimmedLine.StartsWith("```"))
            {
                inCodeBlock = !inCodeBlock;
                if (inCodeBlock)
                {
                    result.AppendLine("<pre><code>");
                }
                else
                {
                    result.AppendLine("</code></pre>");
                }
                continue;
            }

            if (inCodeBlock)
            {
                result.AppendLine(System.Net.WebUtility.HtmlEncode(line));
                continue;
            }

            // 处理行内代码
            var processedLine = line;
            while (processedLine.Contains("`"))
            {
                var codeStart = processedLine.IndexOf('`');
                var codeEnd = processedLine.IndexOf('`', codeStart + 1);
                if (codeStart >= 0 && codeEnd > codeStart)
                {
                    var codeText = processedLine.Substring(codeStart + 1, codeEnd - codeStart - 1);
                    processedLine = processedLine.Substring(0, codeStart) +
                                   $"<code>{System.Net.WebUtility.HtmlEncode(codeText)}</code>" +
                                   processedLine.Substring(codeEnd + 1);
                }
                else
                {
                    break;
                }
            }

            // 处理标题（添加锚点）
            if (trimmedLine.StartsWith("# "))
            {
                sectionIndex++;
                var titleText = processedLine.Substring(2);
                processedLine = $"<h1 id=\"section-{sectionIndex}\">{titleText}</h1>";
            }
            else if (trimmedLine.StartsWith("## "))
            {
                sectionIndex++;
                var titleText = processedLine.Substring(3);
                processedLine = $"<h2 id=\"section-{sectionIndex}\">{titleText}</h2>";
            }
            else if (trimmedLine.StartsWith("### "))
            {
                sectionIndex++;
                var titleText = processedLine.Substring(4);
                processedLine = $"<h3 id=\"section-{sectionIndex}\">{titleText}</h3>";
            }
            else if (trimmedLine.StartsWith("#### "))
            {
                sectionIndex++;
                var titleText = processedLine.Substring(5);
                processedLine = $"<h4 id=\"section-{sectionIndex}\">{titleText}</h4>";
            }
            // 处理列表
            else if (trimmedLine.StartsWith("- ") || trimmedLine.StartsWith("* "))
            {
                processedLine = $"<li>{processedLine.Substring(2)}</li>";
            }
            // 处理表格
            else if (trimmedLine.StartsWith("|"))
            {
                var cells = trimmedLine.Split('|').Where(c => !string.IsNullOrWhiteSpace(c)).ToArray();
                var tag = cells[0].Trim().StartsWith("---") ? "th" : "td";
                processedLine = "<tr>" + string.Join("", cells.Select(c => $"<{tag}>{c.Trim()}</{tag}>")) + "</tr>";
            }
            // 处理引用
            else if (trimmedLine.StartsWith("> "))
            {
                processedLine = $"<blockquote>{processedLine.Substring(2)}</blockquote>";
            }
            // 处理分隔线
            else if (trimmedLine.StartsWith("---"))
            {
                processedLine = "<hr />";
            }
            // 普通段落
            else if (!string.IsNullOrWhiteSpace(trimmedLine))
            {
                processedLine = $"<p>{processedLine}</p>";
            }

            result.AppendLine(processedLine);
        }

        return result.ToString();
    }

    private void ExtractTableOfContents(string markdown)
    {
        tableOfContents.Clear();
        var lines = markdown.Split('\n');
        int sectionIndex = 0;

        foreach (var line in lines)
        {
            var trimmedLine = line.Trim();

            if (trimmedLine.StartsWith("# "))
            {
                sectionIndex++;
                tableOfContents.Add(new TocItem
                {
                    Index = sectionIndex,
                    Text = trimmedLine.Substring(2),
                    Anchor = $"#section-{sectionIndex}",
                    Level = 0
                });
            }
            else if (trimmedLine.StartsWith("## "))
            {
                sectionIndex++;
                tableOfContents.Add(new TocItem
                {
                    Index = sectionIndex,
                    Text = trimmedLine.Substring(3),
                    Anchor = $"#section-{sectionIndex}",
                    Level = 1
                });
            }
            else if (trimmedLine.StartsWith("### "))
            {
                sectionIndex++;
                tableOfContents.Add(new TocItem
                {
                    Index = sectionIndex,
                    Text = trimmedLine.Substring(4),
                    Anchor = $"#section-{sectionIndex}",
                    Level = 2
                });
            }
        }
    }

    private string GetTocActiveClass(int index)
    {
        return string.Empty; // 通过 JavaScript 动态添加 active 类
    }

    private async Task ScrollToSection(string sectionId)
    {
        var jsCode = $@"document.getElementById('{sectionId}')?.scrollIntoView({{
            behavior: 'smooth',
            block: 'start'
        }});";
        await JSRuntime.InvokeVoidAsync("eval", jsCode);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/blog");
    }
}
