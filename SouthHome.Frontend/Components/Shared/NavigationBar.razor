@inject NavigationManager Navigation

<nav style="background: linear-gradient(135deg, #1a1a1a 0%, #dc2626 100%); box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3); position: sticky; top: 0; z-index: 1000;">
    <div class="navbar-container">
        <!-- 左侧：Logo -->
        <div class="navbar-brand">
            <NavLink href="/" Style="text-decoration: none;">
                <span class="logo-text">SouthHome</span>
            </NavLink>
        </div>

        <!-- 中间：导航链接 -->
        <div class="navbar-menu">
            @foreach (var navItem in NavItems)
            {
                <NavLink href="@navItem.Href" class="nav-link" style="text-decoration: none;">
                    <i class="@navItem.Icon"></i>
                    <span>@navItem.Label</span>
                </NavLink>
            }
        </div>

        <!-- 右侧：登录/注册按钮 -->
        <div class="navbar-actions">
            <button class="btn btn-login" onclick="@NavigateToLogin">
                <i class="fa-solid fa-arrow-right-to-bracket"></i>
                <span>登录</span>
            </button>
            <button class="btn btn-register" onclick="@NavigateToRegister">
                <i class="fa-solid fa-user-plus"></i>
                <span>注册</span>
            </button>
        </div>
    </div>
</nav>

<style>
    .navbar-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1400px;
        margin: 0 auto;
        height: 64px;
        padding: 0 24px;
    }

    .navbar-brand {
        flex-shrink: 0;
    }

    .logo-text {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
        letter-spacing: 1px;
    }

    .navbar-menu {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .nav-link:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    .nav-link.active {
        background: rgba(220, 38, 38, 0.3);
        color: #dc2626;
    }

    .nav-link i {
        font-size: 1.1rem;
    }

    .navbar-actions {
        display: flex;
        gap: 0.75rem;
        flex-shrink: 0;
    }

    .btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1.25rem;
        border-radius: 20px;
        font-weight: 500;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        border: none;
    }

    .btn i {
        font-size: 0.95rem;
    }

    .btn-login {
        background: rgba(255, 255, 255, 0.15);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .btn-login:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: translateY(-2px);
    }

    .btn-register {
        background: #dc2626;
        color: white;
    }

    .btn-register:hover {
        background: #e53935;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.4);
    }

    @@media (max-width: 768px) {
        .navbar-container {
            padding: 0 1rem;
            height: 56px;
        }

        .navbar-menu {
            display: none;
        }

        .navbar-actions {
            gap: 0.5rem;
        }

        .btn {
            padding: 0.4375rem 0.875rem;
            font-size: 0.8125rem;
        }

        .btn span {
            display: none;
        }

        .btn i {
            margin: 0;
        }
    }
</style>

@code {
    private List<NavItem> NavItems = new()
    {
        new() { Label = "首页", Icon = "fa-solid fa-house", Href = "/" },
        new() { Label = "博客", Icon = "fa-solid fa-pen-nib", Href = "/blog" },
        new() { Label = "作品集", Icon = "fa-solid fa-folder-open", Href = "/portfolio" },
        new() { Label = "关于我", Icon = "fa-solid fa-user", Href = "/about" }
    };

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void NavigateToRegister()
    {
        Navigation.NavigateTo("/register");
    }

    public class NavItem
    {
        public required string Label { get; set; }
        public required string Icon { get; set; }
        public required string Href { get; set; }
    }
}
