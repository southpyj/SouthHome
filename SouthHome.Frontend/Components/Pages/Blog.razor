@page "/blog"

<PageTitle>博客 - SouthHome</PageTitle>

<div class="blog-page">
    <div class="blog-container">
        <!-- 左侧边栏 -->
        <aside class="sidebar">
            <!-- 分类列表 -->
            <div class="sidebar-section">
                <div class="sidebar-title">
                    <i class="fa-solid fa-folder"></i>
                    <span>分类</span>
                </div>
                <div class="category-list">
                    @foreach (var category in Categories)
                    {
                        <div class="category-item @(category.IsActive ? "active" : "")">
                            <span>@category.Name</span>
                            <span class="count">@category.Count</span>
                        </div>
                    }
                </div>
            </div>

            <!-- 标签云 -->
            <div class="sidebar-section">
                <div class="sidebar-title">
                    <i class="fa-solid fa-tags"></i>
                    <span>标签</span>
                </div>
                <div class="tags-cloud">
                    @foreach (var tag in Tags)
                    {
                        <a href="#" class="tag">
                            @tag.Name
                        </a>
                    }
                </div>
            </div>

            <!-- 最近文章 -->
            <div class="sidebar-section">
                <div class="sidebar-title">
                    <i class="fa-solid fa-clock"></i>
                    <span>最近文章</span>
                </div>
                <div class="recent-posts">
                    @foreach (var post in RecentPosts)
                    {
                        <a href="#" class="recent-post">
                            <div class="post-thumbnail"></div>
                            <div class="post-info">
                                <div class="post-title">@post.Title</div>
                                <div class="post-date">@post.Date</div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </aside>

        <!-- 主内容区域 -->
        <main class="blog-main">
            <article class="blog-post">
                <!-- 文章头部 -->
                <div class="post-header">
                    <h1 class="post-title">深入理解 ASP.NET Core 中间件机制</h1>
                    <div class="post-meta">
                        <div class="meta-item">
                            <i class="fa-solid fa-user"></i>
                            <span>张三</span>
                        </div>
                        <div class="meta-item">
                            <i class="fa-solid fa-calendar"></i>
                            <span>2025-03-08</span>
                        </div>
                        <div class="meta-item">
                            <i class="fa-solid fa-clock"></i>
                            <span>阅读时间：8 分钟</span>
                        </div>
                    </div>
                </div>

                <!-- 文章内容 -->
                <div class="post-content">
                    <p>
                        ASP.NET Core 中间件是处理 HTTP 请求和响应的软件管道，它在请求处理管道中的特定点插入代码。
                    </p>
                    <h2>什么是中间件</h2>
                    <p>
                        中间件是装配到应用程序管道上的一个类，它可以选择处理请求的方式以及是否将请求传递到下一个中间件。
                    </p>
                    <p>
                        在 ASP.NET Core 中，中间件是一个委托类型，它接收 HttpContext 并返回一个 Task。当多个中间件组合在一起时，它们形成一个请求处理管道。
                    </p>
                    <h2>中间件的执行顺序</h2>
                    <p>
                        中间件的执行顺序对于应用程序的行为至关重要。每个中间件都可以决定是否将请求传递到管道中的下一个中间件。
                    </p>
                    <h2>使用中间件</h2>
                    <p>
                        ASP.NET Core 提供了多种内置中间件，如身份验证、授权、会话、路由、静态文件等。
                    </p>
                    <h2>自定义中间件</h2>
                    <p>
                        我们可以创建自定义中间件来满足特定的需求。例如，我们可以创建一个中间件来记录请求信息，或者创建一个中间件来处理异常。
                    </p>
                    <h2>中间件的配置</h2>
                    <p>
                        中间件可以在 Startup 类或 Program 类中配置。在 .NET 6 和更高版本中，我们通常使用 Program 类来配置中间件。
                    </p>
                    <h2>中间件的最佳实践</h2>
                    <p>
                        在使用中间件时，有一些最佳实践需要遵循，例如保持中间件的无状态性、避免阻塞、合理使用依赖注入等。
                    </p>
                    <h2>总结</h2>
                    <p>
                        中间件是 ASP.NET Core 应用程序的核心概念之一，理解它的工作原理对于开发高质量的应用程序至关重要。
                    </p>
                </div>

                <!-- 文章标签 -->
                <div class="post-tags">
                    <span>标签：</span>
                    @foreach (var item in PostTags)
                    {
                        <span class="tag">@item</span>
                    }
                </div>
            </article>
        </main>
    </div>
</div>

<style>
    :root {
        --primary-red: #dc2626;
        --primary-dark: #e53935;
        --black: #1a1a1a;
        --bg-light: #f5f5f7;
        --border-color: #e5e5e5;
        --text-secondary: #666;
    }

    .blog-page {
        min-height: 100vh;
        background: var(--bg-light);
    }

    .blog-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 2.5rem;
    }

    /* 侧边栏 */
    .sidebar {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .sidebar-section {
        background: white;
        border-radius: 16px;
        padding: 1.5rem;
        border: 1px solid var(--border-color);
    }

    .sidebar-title {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--black);
        margin-bottom: 1rem;
    }

    .sidebar-title i {
        color: var(--primary-red);
        font-size: 1.25rem;
    }

    /* 分类列表 */
    .category-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .category-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        color: var(--text-secondary);
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .category-item:hover {
        background: rgba(220, 38, 38, 0.1);
        color: var(--primary-red);
    }

    .category-item.active {
        background: var(--primary-red);
        color: white;
    }

    .category-item .count {
        font-size: 0.875rem;
        font-weight: 500;
        background: rgba(0, 0, 0, 0.1);
        padding: 0.125rem 0.5rem;
        border-radius: 12px;
    }

    /* 标签云 */
    .tags-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        padding: 0.375rem 0.875rem;
        background: var(--bg-light);
        border-radius: 20px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: calc(0.875rem + var(--size) * 0.5rem);
        transition: all 0.3s ease;
        border: 1px solid var(--border-color);
    }

    .tag:hover {
        background: var(--primary-red);
        border-color: var(--primary-red);
        color: white;
        transform: translateY(-2px);
    }

    /* 最近文章 */
    .recent-posts {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .recent-post {
        display: flex;
        gap: 0.75rem;
        padding: 0.75rem;
        border-radius: 12px;
        transition: all 0.3s ease;
        text-decoration: none;
        color: var(--text-secondary);
    }

    .recent-post:hover {
        background: rgba(220, 38, 38, 0.05);
        transform: translateX(4px);
    }

    .post-thumbnail {
        width: 80px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary-red), var(--primary-dark));
        border-radius: 8px;
        flex-shrink: 0;
    }

    .post-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .recent-post .post-title {
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--black);
        margin-bottom: 0.25rem;
        line-height: 1.3;
    }

    .recent-post .post-date {
        font-size: 0.8125rem;
        color: #999;
    }

    /* 主内容区域 */
    .blog-main {
        background: white;
        border-radius: 16px;
        padding: 2.5rem;
        border: 1px solid var(--border-color);
    }

    .blog-post {
        max-width: 100%;
    }

    .post-header {
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border-color);
        margin-bottom: 2rem;
    }

    .post-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--black);
        margin-bottom: 1.5rem;
        line-height: 1.4;
    }

    .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9375rem;
        color: var(--text-secondary);
    }

    .meta-item i {
        color: var(--primary-red);
    }

    .post-content {
        color: #333;
        line-height: 1.9;
    }

    .post-content h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--black);
        margin: 2rem 0 0 -1rem;
    }

    .post-content p {
        margin-bottom: 1.5rem;
    }

    .post-tags {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.5rem 0;
        border-top: 1px solid var(--border-color);
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .post-tags span {
        color: var(--text-secondary);
        font-size: 0.9375rem;
    }

    .post-tags .tag {
        background: var(--primary-red);
        color: white;
        font-size: 0.875rem;
    }

    .post-tags .separator {
        color: var(--border-color);
        font-size: 0.875rem;
    }

    @@media (max-width: 1024px) {
        .blog-container {
            grid-template-columns: 1fr;
        }

        .sidebar {
            display: none;
        }
    }

    @@media (max-width: 768px) {
        .blog-container {
            padding: 1rem 1rem;
        }

        .blog-main {
            padding: 1.5rem;
        }

        .post-title {
            font-size: 1.5rem;
        }

        .post-meta {
            gap: 1rem;
            flex-direction: column;
            align-items: flex-start;
        }

        .post-content h2 {
            font-size: 1.25rem;
        }
    }
</style>

@code {
    private List<Category> Categories = new()
    {
        new() { Name = "后端开发", Count = 12, IsActive = true },
        new() { Name = "前端开发", Count = 8, IsActive = false },
        new() { Name = "数据库", Count = 5, IsActive = false },
        new() { Name = "架构设计", Count = 3, IsActive = false },
        new() { Name = "DevOps", Count = 2, IsActive = false }
    };

    private List<Tag> Tags = new()
    {
        new() { Name = "ASP.NET", Size = 100 },
        new() { Name = "Blazor", Size = 90 },
        new() { Name = "PostgreSQL", Size = 85 },
        new() { Name = "Docker", Size = 75 },
        new() { Name = "EF Core", Size = 70 },
        new() { Name = "中间件", Size = 65 },
        new() { Name = "Web API", Size = 80 },
        new() { Name = "JWT", Size = 55 },
        new() { Name = "OAuth", Size = 50 }
    };

    private List<RecentPost> RecentPosts = new()
    {
        new() { Title = "Blazor 组件开发最佳实践", Date = "2025-03-05" },
        new() { Title = "PostgreSQL 性能优化技巧分享", Date = "2025-03-01" },
        new() { Title = "从零搭建前后端分离项目架构", Date = "2025-02-28" },
        new() { Title = "现代前端状态管理方案对比", Date = "2025-02-25" },
        new() { Title = "Docker 容器化部署完整指南", Date = "2025-02-20" }
    };

    private List<string> PostTags = new()
    {
        "ASP.NET Core",
        "中间件",
        "Web开发"
    };

    public class Category
    {
        public required string Name { get; set; }
        public int Count { get; set; }
        public bool IsActive { get; set; }
    }

    public class Tag
    {
        public required string Name { get; set; }
        public int Size { get; set; }
    }

    public class RecentPost
    {
        public required string Title { get; set; }
        public required string Date { get; set; }
    }
}
